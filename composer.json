{
    "name": "lukman-ss/intisari-starter",
    "description": "Starter project for IntisariPHP applications.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "lukman-ss/intisari": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "console": "php intisari",
        "serve": "php intisari serve"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
